.git
.gitignore
.dockerignore
.env
.env.*
!.env.example

node_modules

# Local runtime artifacts
data/
studio/.stats.json
studio/.stats.json.tmp
studio/.studio.log

# Tooling state, not needed in image — except critiques, which back the
# catalog's critic-grades view (Dockerfile COPYs them as the no-mount default).
.superpowers/
.claude/
brainstorming/
!brainstorming/critiques/
# Evidence snapshots are heavy media — served via the compose bind mount,
# never baked into the image.
brainstorming/critiques/evidence/
tests/
VISION.md
README.md

# Heavy generated outputs — never copy into the image
pieces/*/clip.webm
pieces/*/clip.mp4
pieces/index.json

.DS_Store
