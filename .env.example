# Copy to `.env` and fill in. .env is gitignored.

# Token guarding GET /api/stats. Required in any deployment that's
# reachable from the public internet. Generate with:
#   openssl rand -hex 24
STATS_TOKEN=replace-me-with-a-long-random-string

# Optional. Defaults are fine for the docker-compose setup.
# STUDIO_HOST=0.0.0.0
# STUDIO_PORT=7777
# STATS_FILE=/app/data/stats.json
